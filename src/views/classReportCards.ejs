<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Class Report Cards - <%= className %> <%= academicYear %></title>

<style>
@page {
    size: A4 portrait;
    margin: 0;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html, body {
    margin: 0;
    padding: 0;
    width: 210mm;
    font-family: "Times New Roman", serif;
    background: #fff;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
}

.page-container {
    width: 200mm;
    min-height: 277mm;
    margin: 0 auto;
    padding: 10mm 8mm;
    border: 2px solid #000;
    position: relative;
    page-break-after: always;
    box-sizing: border-box;
    background: #fff;
    display: flex;
    flex-direction: column;
}

.page-container:last-child {
    page-break-after: auto;
}

/* Logo Watermark */
.logo-watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 140mm;
    height: 140mm;
    opacity: 0.04;
    z-index: 1;
    pointer-events: none;
}

.logo-watermark img {
    width: 100%;
    height: 100%;
    object-fit: contain;
}

.content-layer {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    flex: 1;
}

/* Main content */
.main-content {
    flex: 1;
}

/* Header Section */
.header-section {
    text-align: center;
    margin-bottom: 15px;
}

.school-logo {
    width: 25mm;
    height: 25mm;
    margin: 0 auto 5px;
}

.school-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
}

.school-name {
    font-size: 14px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 3px;
}

.arabic-text {
    font-size: 12px;
    font-weight: bold;
    margin-bottom: 5px;
    color: #333;
}

.report-title {
    font-size: 16px;
    font-weight: 900;
    text-transform: uppercase;
    text-decoration: underline;
    margin-bottom: 8px;
}

.class-info {
    font-size: 12px;
    font-weight: bold;
    margin-bottom: 5px;
}

/* Student Info */
.student-info {
    margin-bottom: 15px;
    font-size: 11px;
    border: 1px solid #000;
    padding: 5px;
    background: #fafafa;
}

.info-row {
    margin-bottom: 3px;
    font-weight: bold;
}

.info-label {
    display: inline-block;
    width: 85px;
}

.info-value {
    font-weight: normal;
}

/* Marks Table */
.marks-table {
    width: 100%;
    border-collapse: collapse;
    margin: 10px 0;
    font-size: 9px;
}

.marks-table th,
.marks-table td {
    border: 1.5px solid #000;
    padding: 4px 3px;
    text-align: center;
    vertical-align: middle;
}

.marks-table th {
    background: #f0f0f0;
    font-weight: 900;
    text-transform: uppercase;
    font-size: 8px;
}

.marks-table td:first-child {
    text-align: left;
    font-weight: 600;
    padding-left: 6px;
}

/* Total Row */
.total-row {
    font-weight: 900;
    background: #f0f0f0;
}

.total-row td {
    font-weight: 900;
}

/* Attendance Section */
.attendance-section {
    margin: 10px 0;
    padding: 5px 8px;
    border: 1.5px solid #000;
    background: #fff;
}

.attendance-row {
    display: flex;
    justify-content: space-between;
    font-size: 10px;
    font-weight: 700;
}

/* Signature Section */
.signature-section {
    margin-top: 15px;
    display: flex;
    justify-content: space-between;
    gap: 20px;
}

.signature-item {
    flex: 1;
    text-align: center;
}

.signature-label {
    font-size: 9px;
    font-weight: 700;
    margin-bottom: 15px;
}

.signature-line {
    border-top: 1.5px solid #000;
    width: 100%;
    margin-top: 5px;
}

/* Bottom Info Row */
.bottom-info-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-top: 10px;
    border-top: 1px solid #000;
    padding-top: 5px;
}

.grade-info {
    font-size: 8px;
    font-weight: bold;
    text-align: left;
}

.generated-info {
    font-size: 8px;
    color: #666;
    text-align: right;
}

.page-number {
    text-align: center;
    font-size: 9px;
    margin-top: 5px;
    font-weight: bold;
}

/* Print optimization */
@media print {
    html, body {
        width: 210mm;
        margin: 0;
        padding: 0;
    }
    
    th {
        background: #f0f0f0 !important;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }
    
    .total-row td {
        background: #f0f0f0 !important;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }
    
    .page-container {
        border: 2px solid #000;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
        page-break-after: always;
    }
    
    .logo-watermark {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }
}
</style>
</head>

<body>

<%
let pageNum = 1;
const totalStudents = students.length;

students.forEach(function(student, index) {
    const data = student;
%>

<div class="page-container">
    
    <!-- Logo Watermark -->
    <div class="logo-watermark">
        <img src="<%= schoolLogo %>" alt="Watermark">
    </div>
    
    <div class="content-layer">
        
        <div class="main-content">
            
            <!-- Header -->
            <div class="header-section">
                <div class="school-logo">
                    <img src="<%= schoolLogo %>" alt="School Logo">
                </div>
                <div class="school-name">P.P.M.H.S.S. KOTTUKKARA</div>
                <div class="report-title">PROGRESS REPORT - <%= academicYear %></div>
                <div class="exam-info" style="font-size: 11px; font-weight: bold; margin-top: 3px;"> <%= examName %></div>
                <div class="class-info">Class: <%= className %></div>
            </div>
            
            <!-- Student Info -->
            <div class="student-info">
                <div class="info-row">
                    <span class="info-label">Name</span>
                    <span class="info-value">: <%= data.student.name %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Roll Number</span>
                    <span class="info-value">: <%= data.student.rollNumber %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Admission No.</span>
                    <span class="info-value">: <%= data.student.admissionNo %></span>
                </div>
            </div>
            
            <!-- Marks Table -->
            <% if (data.subjects && data.subjects.length > 0) { %>
            <table class="marks-table">
                <thead>
                    <tr>
                        <th rowspan="2">SUBJECT</th>
                        <th colspan="2">Max. Score</th>
                        <th colspan="2">Score Obtained</th>
                        <th rowspan="2">TOTAL</th>
                        <th rowspan="2">GRADE</th>
                    </tr>
                    <tr>
                        <th>CE</th>
                        <th>TE</th>
                        <th>CE</th>
                        <th>TE</th>
                    </tr>
                </thead>
                <tbody>
                <% 
                let totalCEMax = 0;
                let totalTEMax = 0;
                let totalCE = 0;
                let totalTE = 0;
                
                data.subjects.forEach(function(subject) {
                    totalCEMax += subject.ceMax;
                    totalTEMax += subject.teMax;
                    totalCE += subject.ceMarks;
                    totalTE += subject.teMarks;
                %>
                <tr>
                    <td><%= subject.name %></td>
                    <td><%= subject.ceMax %></td>
                    <td><%= subject.teMax %></td>
                    <td><%= subject.ceMarks %></td>
                    <td><%= subject.teMarks %></td>
                    <td><%= subject.total %></td>
                    <td><%= subject.grade %></td>
                </tr>
                <% }); %>
                
                <tr class="total-row">
                    <td><strong>TOTAL</strong></td>
                    <td><strong><%= data.totalCEMax %></strong></td>
                    <td><strong><%= data.totalTEMax %></strong></td>
                    <td><strong><%= data.totalCE %></strong></td>
                    <td><strong><%= data.totalTE %></strong></td>
                    <td><strong><%= data.grandTotal %></strong></td>
                    <td><strong><%= data.overallPercentage %>%</strong></td>
                </tr>
                </tbody>
            </table>
            <% } else { %>
            <div style="text-align: center; padding: 20px; color: #999; font-style: italic;">
                No marks available for this student
            </div>
            <% } %>
            
            <!-- Attendance -->
            <div class="attendance-section">
                <div class="attendance-row">
                    <span>Working Days: <%= data.attendance.totalDays %></span>
                    <span>Days Present: <%= data.attendance.presentDays %></span>
                    <span>Attendance: <%= data.attendance.percentage %>%</span>
                </div>
            </div>
            
            <!-- Remarks Section -->
            <div style="margin-top: 15px; font-size: 10px; font-weight: bold;">
                <span style="display: inline-block; width: 60px;">Remarks :</span>
                <span style="display: inline-block; width: 550px; border-bottom: 1px solid #000;"></span>
            </div>
            
        </div>
        
        <!-- Bottom Section -->
        <div class="bottom-section">
            
            <!-- Signatures -->
            <div class="signature-section">
                <div class="signature-item">
                    <div class="signature-label">Class Teacher</div>
                    <div class="signature-line"></div>
                </div>
                <div class="signature-item">
                    <div class="signature-label">Principal</div>
                    <div class="signature-line"></div>
                </div>
                <div class="signature-item">
                    <div class="signature-label">Parent's Signature</div>
                    <div class="signature-line"></div>
                </div>
            </div>
            
            <!-- Bottom Info Row -->
            <div class="bottom-info-row">
                <div class="grade-info">
                    Overall Grade: <%= data.overallGrade %> | Promoted to next class on: ___________________
                </div>
                <div class="generated-info">
                    Generated: <%= new Date().toLocaleDateString('en-IN') %>
                </div>
            </div>
            
        </div>
        
        <div class="page-number">Page <%= pageNum %> of <%= totalStudents %></div>
    </div>
</div>

<% 
    pageNum++;
}); 
%>

</body>
</html>