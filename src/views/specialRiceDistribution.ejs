<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Special Rice Distribution - <%= className %> <%= academicYear %></title>

<style>
@page {
    size: A4 portrait;
    margin: 0;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html, body {
    margin: 0;
    padding: 0;
    width: 210mm;
    height: 297mm;
    font-family: "Times New Roman", serif;
    background: #fff;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
}

.page-container {
    width: 100%;
    min-height: 100%;
    padding: 10mm 8mm;
    border: 2px solid #000;
    position: relative;
    page-break-after: always;
    box-sizing: border-box;
    background: #fff;
    display: flex;
    flex-direction: column;
}

.page-container:last-child {
    page-break-after: auto;
}

/* Logo Watermark - Centered */
.logo-watermark {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    pointer-events: none;
}

.logo-watermark img {
    max-width: 120mm;
    max-height: 120mm;
    width: auto;
    height: auto;
    opacity: 0.04;
    object-fit: contain;
}

.logo-watermark .watermark-text {
    font-size: 40px;
    font-weight: bold;
    color: rgba(0, 0, 0, 0.04);
    text-transform: uppercase;
    letter-spacing: 5px;
    white-space: nowrap;
    transform: rotate(-45deg);
}

.content-layer {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    flex: 1;
}

/* Main content area */
.main-content {
    flex: 1;
}

/* Header Section */
.header-section {
    text-align: center;
    margin-bottom: 8px;
}

.school-logo {
    width: 20mm;
    height: 20mm;
    margin: 0 auto 3px;
}

.school-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
}

.school-name {
    font-size: 13px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 2px;
}

.arabic-text {
    font-size: 11px;
    font-weight: bold;
    margin-bottom: 2px;
    color: #333;
}

.main-title {
    font-size: 14px;
    font-weight: 900;
    text-transform: uppercase;
    margin-bottom: 3px;
}

/* Header Row */
.header-row {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 5px;
    margin-top: 5px;
    font-size: 10px;
}

.header-row td {
    border: 1.5px solid #000;
    padding: 5px 3px;
    text-align: center;
    font-weight: bold;
    vertical-align: middle;
}

/* Main Table */
.main-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 8px;
    margin-top: 5px;
    table-layout: fixed;
}

.main-table th,
.main-table td {
    border: 1.5px solid #000;
    padding: 4px 2px;
    text-align: center;
    vertical-align: middle;
}

.main-table th {
    background: transparent;
    font-weight: 900;
    text-transform: uppercase;
    font-size: 7.5px;
    padding: 5px 2px;
}

.main-table td {
    background: transparent;
}

/* Column widths */
.main-table .sl-col { width: 6%; }
.main-table .adm-col { width: 8%; }
.main-table .name-col { width: 22%; text-align: left; padding-left: 4px; }
.main-table .uid-col { width: 15%; }
.main-table .parent-col { width: 24%; text-align: left; padding-left: 4px; }
.main-table .qty-col { width: 10%; }
.main-table .sign-col { width: 15%; }

/* Bottom Section */
.bottom-section {
    margin-top: auto;
    padding-top: 10px;
}

/* Signature Section */
.signature-section {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 5px;
}

.signature-left {
    font-size: 9px;
    font-weight: bold;
}

.signature-right {
    font-size: 9px;
    font-weight: bold;
    text-align: right;
}

.signature-line {
    display: inline-block;
    width: 150px;
    border-bottom: 1px solid #000;
    margin-left: 5px;
}

/* Footer */
.footer {
    padding-top: 6px;
    border-top: 1px solid #000;
    font-size: 9px;
    text-align: center;
    font-weight: bold;
    overflow: hidden;
}

.page-number {
    text-align: center;
    float: right;
}

.total-students {
    float: left;
    font-weight: 700;
    font-size: 8px;
}

.generated-info {
    float: right;
    font-size: 7px;
    color: #666;
}

/* Print optimization */
@media print {
    html, body {
        width: 210mm;
        height: 297mm;
        margin: 0;
        padding: 0;
    }
    
    th {
        background: transparent !important;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }
    
    td {
        background: transparent !important;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }
    
    .page-container {
        border: 2px solid #000;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
        page-break-after: always;
    }
    
    .logo-watermark {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }
}
</style>
</head>

<body>

<%
const studentsPerPage = 40;
const totalPages = Math.ceil(students.length / studentsPerPage);
const displayAcademicYear = typeof academicYear !== 'undefined' ? academicYear : '2025-2026';
const displayClassName = typeof className !== 'undefined' ? className : '8 A';
const displayMonth = typeof month !== 'undefined' ? month : 'March 2026';
const displaySchoolName = typeof schoolName !== 'undefined' ? schoolName : 'P.P.M.H.S.S. KOTTUKKARA';
const displaySchoolLogo = typeof schoolLogo !== 'undefined' ? schoolLogo : '';

for (let page = 0; page < totalPages; page++) {
    const startIndex = page * studentsPerPage;
    const endIndex = Math.min(startIndex + studentsPerPage, students.length);
    const pageStudents = students.slice(startIndex, endIndex);
    const isFirstPage = page === 0;
    const isLastPage = page === totalPages - 1;
%>

<div class="page-container">
    
    <!-- Logo Watermark - Centered -->
    <div class="logo-watermark">
        <% if (displaySchoolLogo) { %>
            <img src="<%= displaySchoolLogo %>" alt="Watermark">
        <% } else { %>
            <div class="watermark-text"><%= displaySchoolName %></div>
        <% } %>
    </div>
    
    <div class="content-layer">
        
        <div class="main-content">
            
            <div class="header-section">
                <% if (isFirstPage && displaySchoolLogo) { %>
                <div class="school-logo">
                    <img src="<%= displaySchoolLogo %>" alt="School Logo">
                </div>
                <% } %>
                <div class="school-name"><%= displaySchoolName %></div>
                <div class="main-title">Special Rice Distribution</div>
            </div>
            
            <table class="header-row">
                <tr>
                    <td colspan="7">For the Month of <%= displayMonth %></td>
                    <td colspan="5">Class & Division : <%= displayClassName %></td>
                    <td colspan="4"><%= displayAcademicYear %></td>
                </tr>
            </table>
            
            <table class="main-table">
                <thead>
                    <tr>
                        <th class="sl-col">Sl No</th>
                        <th class="adm-col">Adm. No</th>
                        <th class="name-col">Name of Student</th>
                        <th class="uid-col">UID</th>
                        <th class="parent-col">Name of Parent</th>
                        <th class="qty-col">Quantity<br>of Rice</th>
                        <th class="sign-col">Signature</th>
                    </tr>
                </thead>
                <tbody>
                    <% pageStudents.forEach(function(student, index) { 
                        const slNo = startIndex + index + 1;
                    %>
                    <tr>
                        <td><%= slNo %></td>
                        <td><%= student.admissionNo %></td>
                        <td style="text-align: left; padding-left: 4px;"><%= student.name %></td>
                        <td><%= student.uid || '-' %></td>
                        <td style="text-align: left; padding-left: 4px;"><%= student.parentName %></td>
                        <td>&nbsp;</td>
                        <td>&nbsp;</td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
            
        </div>
        
        <% if (isLastPage) { %>
        <div class="bottom-section">
            <div class="signature-section">
                <div class="signature-left">
                    Name and signature of class teacher : <span class="signature-line"></span>
                </div>
                <div class="signature-right">
                    Signature of HM : <span class="signature-line"></span>
                </div>
            </div>
        </div>
        <% } %>
        
        <div class="footer">
            <span class="total-students">Total Students: <%= students.length %></span>
            <span class="generated-info"><%= new Date().toLocaleDateString('en-IN') %></span>
            <span class="page-number">Page <%= page + 1 %> of <%= totalPages %></span>
        </div>
        
    </div>
</div>

<% } %>

</body>
</html>