<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>ID Card List - <%= className %> <%= academicYear %></title>

<style>
@page {
    size: A4 portrait;
    margin: 5mm;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html, body {
    margin: 0;
    padding: 0;
    width: 210mm;
    font-family: 'Times New Roman', 'Arial', sans-serif;
    background: #fff;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
}

/* Page Container - Each page gets border */
.page-container {
    width: 200mm;
    min-height: 287mm;
    margin: 0 auto 5mm auto;
    padding: 5mm;
    border: 2px solid #000;
    position: relative;
    page-break-after: always;
    box-sizing: border-box;
}

/* Last page doesn't need page break after */
.page-container:last-child {
    page-break-after: auto;
    margin-bottom: 0;
}

/* Watermark */
.watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(-45deg);
    font-size: 70px;
    font-weight: bold;
    color: rgba(0, 0, 0, 0.04);
    white-space: nowrap;
    pointer-events: none;
    z-index: 1;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-family: 'Times New Roman', serif;
    width: 100%;
    text-align: center;
}

/* Content Layer - Above watermark */
.content-layer {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
}

/* Header */
.header {
    text-align: center;
    margin-bottom: 10px;
    padding-bottom: 8px;
    border-bottom: 2px solid #000;
}

.school-name {
    font-size: 20px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 3px;
}

.school-address {
    font-size: 10px;
    margin-bottom: 5px;
}

.title {
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    margin: 5px 0;
}

.class-info {
    font-size: 13px;
    font-weight: 700;
}

.page-number {
    float: right;
    font-size: 9px;
    margin-top: 3px;
    font-weight: bold;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #8e8e8e;
}

/* Table */
.table-container {
    margin-top: 8px;
    flex: 1;
}

table {
    width: 100%;
    border-collapse: collapse;
    font-size: 8.5px;
}

th, td {
    border: 1.5px solid #000;
    padding: 4px 2px;
    text-align: left;
    vertical-align: middle;
    word-break: break-word;
}

th {
    background: #f0f0f0;
    font-weight: 900;
    text-align: center;
    text-transform: uppercase;
    font-size: 8.5px;
    padding: 5px 2px;
}

td {
    background: #fff;
}

/* Column widths for portrait */
th:nth-child(1), td:nth-child(1) { width: 5%; text-align: center; }
th:nth-child(2), td:nth-child(2) { width: 8%; text-align: center; }
th:nth-child(3), td:nth-child(3) { width: 16%; font-weight: 600; }
th:nth-child(4), td:nth-child(4) { width: 16%; }
th:nth-child(5), td:nth-child(5) { width: 11%; text-align: center; }
th:nth-child(6), td:nth-child(6) { width: 11%; text-align: center; }
th:nth-child(7), td:nth-child(7) { width: 33%; }

.text-center { 
    text-align: center; 
}

/* Zebra striping for readability */
tbody tr:nth-child(even) td {
    background-color: #f9f9f9;
}

/* Footer */
.footer {
    margin-top: 10px;
    padding-top: 8px;
    border-top: 1px solid #000;
    overflow: hidden;
}

.total-students {
    float: left;
    font-weight: 700;
    font-size: 10px;
}

.generated-info {
    float: right;
    font-size: 9px;
}

/* Print optimization */
@media print {
    html, body {
        width: 210mm;
        margin: 0;
        padding: 0;
    }
    
    th {
        background: #f0f0f0 !important;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }
    
    tbody tr:nth-child(even) td {
        background-color: #f9f9f9 !important;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }
    
    .page-container {
        border: 2px solid #000;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
        page-break-after: always;
    }
    
    .watermark {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }
}
</style>
</head>

<body>

<%
// Calculate pagination
const studentsPerPage = 40; // Adjust based on how many fit on one page
const totalPages = Math.ceil(students.length / studentsPerPage);

for (let page = 0; page < totalPages; page++) {
    const startIndex = page * studentsPerPage;
    const endIndex = Math.min(startIndex + studentsPerPage, students.length);
    const pageStudents = students.slice(startIndex, endIndex);
    const isFirstPage = page === 0;
%>

<div class="page-container">
    
    <!-- Watermark -->
    <div class="watermark">
        PPM HSS KOTTUKKARA
    </div>
    
    <!-- Content Layer -->
    <div class="content-layer">
        
        <!-- Header (Only on first page) -->
        <% if (isFirstPage) { %>
        <div class="header">
            <div class="school-name">PPM HSS KOTTUKKARA</div>
            <div class="school-address">Kottukkara, Kondotty, Malappuram, Kerala - 673638</div>
            <div class="title">LIST FOR ID CARD</div>
            <!-- <div class="class-info"><%= className %> - <%= academicYear %></div> -->
        </div>
        <% } else { %>
        <!-- Continued header for subsequent pages -->
        <div class="header" style="margin-bottom: 5px; padding-bottom: 5px;">
            <div class="school-name" style="font-size: 16px;">PPM HSS KOTTUKKARA</div>
            <div class="title" style="font-size: 14px;">LIST FOR ID CARD (Continued)</div>
            <div class="class-info" style="font-size: 12px;"><%= className %> - <%= academicYear %></div>
        </div>
        <% } %>
        
       
        
        <!-- Table -->
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Sl No</th>
                        <th>Admn No</th>
                        <th>Name of Student</th>
                        <th>Name of Parent</th>
                        <th>Phone 1</th>
                        <th>Phone 2</th>
                        <th>Street Name</th>
                    </tr>
                </thead>
                <tbody>
                    <% 
                    pageStudents.forEach(function(student, index) { 
                        const slNo = startIndex + index + 1;
                    %>
                    <tr>
                        <td class="text-center"><%= slNo %></td>
                        <td class="text-center"><%= student.admissionNo %></td>
                        <td><%= student.name %></td>
                        <td><%= student.parentName %></td>
                        <td class="text-center"><%= student.phone1 %></td>
                        <td class="text-center"><%= student.phone2 %></td>
                        <td><%= student.street %></td>
                    </tr>
                    <% }); %>
                    
                    <% 
                    // Fill remaining rows with empty cells if needed (optional)
                    const remainingRows = studentsPerPage - pageStudents.length;
                    for (let i = 0; i < remainingRows; i++) {
                    %>
                    <!-- <tr>
                        <td class="text-center">-</td>
                        <td class="text-center">-</td>
                        <td>-</td>
                        <td>-</td>
                        <td class="text-center">-</td>
                        <td class="text-center">-</td>
                        <td>-</td>
                    </tr> -->
                    <% } %>
                </tbody>
            </table>
        </div>
        
        <!-- Footer (Only on last page or all pages) -->
        <% if (page === totalPages - 1) { %>
        <div class="footer">
            <span class="total-students">Total Students: <%= students.length %></span>
            <span class="generated-info">Generated on: <%= new Date().toLocaleDateString('en-IN') %></span>
        </div>
        <% } else { %>
        <div class="footer" style="border-top: none;">
            <!-- <span class="total-students">Continued on next page...</span> -->
        </div>
        <% } %>
        <div class="page-number">Page <%= page + 1 %> of <%= totalPages %></div>
    </div>
</div>

<% } %>

</body>
</html>