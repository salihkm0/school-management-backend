<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>ID Card List - <%= className %> <%= academicYear %></title>

<style>
@page {
    size: A4 portrait;
    margin: 5mm;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html, body {
    margin: 0;
    padding: 0;
    width: 210mm;
    font-family: 'Times New Roman', 'Arial', sans-serif;
    background: #fff;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
}

/* Page Container - Each page gets border */
.page-container {
    width: 200mm;
    min-height: 287mm;
    margin: 0 auto 5mm auto;
    padding: 10mm 8mm;
    border: 2px solid #000;
    position: relative;
    page-break-after: always;
    box-sizing: border-box;
    background: #fff;
    display: flex;
    flex-direction: column;
}

/* Last page doesn't need page break after */
.page-container:last-child {
    page-break-after: auto;
    margin-bottom: 0;
}

/* Logo Watermark */
.logo-watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 140mm;
    height: 140mm;
    opacity: 0.04;
    z-index: 1;
    pointer-events: none;
}

.logo-watermark img {
    width: 100%;
    height: 100%;
    object-fit: contain;
}

.content-layer {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    flex: 1;
}

/* Main content area */
.main-content {
    flex: 1;
}

/* Header */
.header {
    text-align: center;
    margin-bottom: 10px;
    padding-bottom: 8px;
    border-bottom: 2px solid #000;
}

.school-logo {
    width: 25mm;
    height: 25mm;
    margin: 0 auto 5px;
}

.school-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
}

.school-name {
    font-size: 14px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 3px;
}

.arabic-text {
    font-size: 12px;
    font-weight: bold;
    margin-bottom: 5px;
    color: #333;
}

.school-address {
    font-size: 10px;
    margin-bottom: 5px;
}

.title {
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    margin: 5px 0;
}

.class-info {
    font-size: 13px;
    font-weight: 700;
}

/* Table */
.table-container {
    margin-top: 8px;
    flex: 1;
}

table {
    width: 100%;
    border-collapse: collapse;
    font-size: 8.5px;
}

th, td {
    border: 1.5px solid #000;
    padding: 5px 3px;
    text-align: left;
    vertical-align: middle;
    word-break: break-word;
}

th {
    background: #f0f0f000;
    font-weight: 900;
    text-align: center;
    text-transform: uppercase;
    font-size: 8px;
    padding: 6px 2px;
}

td {
    background: #ffffff00;
}

/* Column widths for portrait */
th:nth-child(1), td:nth-child(1) { width: 6%; text-align: center; }
th:nth-child(2), td:nth-child(2) { width: 8%; text-align: center; }
th:nth-child(3), td:nth-child(3) { width: 18%; font-weight: 600; }
th:nth-child(4), td:nth-child(4) { width: 18%; }
th:nth-child(5), td:nth-child(5) { width: 10%; text-align: center; }
th:nth-child(6), td:nth-child(6) { width: 10%; text-align: center; }
th:nth-child(7), td:nth-child(7) { width: 30%; }

.text-center { 
    text-align: center; 
}

/* Zebra striping for readability */
tbody tr:nth-child(even) td {
    background-color: #f9f9f900;
}

/* Footer */
.footer {
    margin-top: 10px;
    padding-top: 8px;
    border-top: 1px solid #000;
    overflow: hidden;
}

.total-students {
    float: left;
    font-weight: 700;
    font-size: 10px;
}

.generated-info {
    float: right;
    font-size: 9px;
}

.page-number {
    text-align: center;
    font-size: 9px;
    margin-top: 5px;
    color: #666;
}

/* Print optimization */
@media print {
    html, body {
        width: 210mm;
        margin: 0;
        padding: 0;
    }
    
    th {
        background: #f0f0f000 !important;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }
    
    tbody tr:nth-child(even) td {
        background-color: #f9f9f900 !important;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }
    
    .page-container {
        border: 2px solid #000;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
        page-break-after: always;
    }
    
    .logo-watermark {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }
}
</style>
</head>

<body>

<%
// Calculate pagination
const studentsPerPage = 35;
const totalPages = Math.ceil(students.length / studentsPerPage);
const displayAcademicYear = typeof academicYear !== 'undefined' ? academicYear : '2025-2026';
const displayClassName = typeof className !== 'undefined' ? className : '8 A';
const displaySchoolName = typeof schoolName !== 'undefined' ? schoolName : 'P.P.M.H.S.S. KOTTUKKARA';
const displaySchoolLogo = typeof schoolLogo !== 'undefined' ? schoolLogo : '';

for (let page = 0; page < totalPages; page++) {
    const startIndex = page * studentsPerPage;
    const endIndex = Math.min(startIndex + studentsPerPage, students.length);
    const pageStudents = students.slice(startIndex, endIndex);
    const isFirstPage = page === 0;
%>

<div class="page-container">
    
    <!-- Logo Watermark -->
    <div class="logo-watermark">
        <% if (displaySchoolLogo) { %>
            <img src="<%= displaySchoolLogo %>" alt="Watermark">
        <% } else { %>
            <div style="font-size: 40px; font-weight: bold; text-align: center; color: rgba(0,0,0,0.04);">
                <%= displaySchoolName %>
            </div>
        <% } %>
    </div>
    
    <div class="content-layer">
        
        <div class="main-content">
            
            <!-- Header (Only on first page) -->
            <% if (isFirstPage) { %>
            <div class="header">
                <% if (displaySchoolLogo) { %>
                <div class="school-logo">
                    <img src="<%= displaySchoolLogo %>" alt="School Logo">
                </div>
                <% } %>
                <div class="school-name"><%= displaySchoolName %></div>
                <div class="school-address">Kottukkara, Kondotty, Malappuram, Kerala - 673638</div>
                <div class="title">ID CARD LIST</div>
                <div class="class-info"><%= displayClassName %> - <%= displayAcademicYear %></div>
            </div>
            <% } else { %>
            <!-- Continued header for subsequent pages -->
            <div class="header" style="margin-bottom: 5px; padding-bottom: 5px;">
                <div class="school-name" style="font-size: 14px;"><%= displaySchoolName %></div>
                <div class="title" style="font-size: 14px;">ID CARD LIST (Continued)</div>
                <div class="class-info" style="font-size: 12px;"><%= displayClassName %> - <%= displayAcademicYear %></div>
            </div>
            <% } %>
            
            <!-- Table -->
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Sl No</th>
                            <th>Admn No</th>
                            <th>Name of Student</th>
                            <th>Name of Parent</th>
                            <th>Phone 1</th>
                            <th>Phone 2</th>
                            <th>Address</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% 
                        pageStudents.forEach(function(student, index) { 
                            const slNo = startIndex + index + 1;
                        %>
                        <tr>
                            <td class="text-center"><%= slNo %></td>
                            <td class="text-center"><%= student.admissionNo %></td>
                            <td><%= student.name %></td>
                            <td><%= student.parentName %></td>
                            <td class="text-center"><%= student.phone1 %></td>
                            <td class="text-center"><%= student.phone2 %></td>
                            <td><%= student.street %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
            
        </div>
        
        <!-- Footer (Only on last page) -->
        <% if (page === totalPages - 1) { %>
        <div class="footer">
            <span class="total-students">Total Students: <%= students.length %></span>
            <span class="generated-info">Generated on: <%= new Date().toLocaleDateString('en-IN') %></span>
        </div>
        <% } %>
        
        <div class="page-number">Page <%= page + 1 %> of <%= totalPages %></div>
        
    </div>
</div>

<% } %>

</body>
</html>