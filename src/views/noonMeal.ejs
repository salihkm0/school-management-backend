<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Noon Meal Programme Consolidation - <%= monthYear %></title>

<style>
@page {
    size: A4 landscape;
    margin: 0;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html, body {
    margin: 0;
    padding: 0;
    width: 297mm;
    height: 210mm;
    font-family: "Times New Roman", serif;
    background: #fff;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
}

/* Page Container - Each page gets border */
.page-container {
    width: 100%;
    min-height: 100%;
    padding: 8mm 8mm;
    border: 2px solid #000;
    position: relative;
    page-break-after: always;
    box-sizing: border-box;
    background: #fff;
    display: flex;
    flex-direction: column;
}

.page-container:last-child {
    page-break-after: auto;
}

/* Logo Watermark - Centered correctly */
.logo-watermark {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    pointer-events: none;
}

.logo-watermark img {
    max-width: 120mm;
    max-height: 120mm;
    width: auto;
    height: auto;
    opacity: 0.04;
    object-fit: contain;
}

.logo-watermark .watermark-text {
    font-size: 40px;
    font-weight: bold;
    color: rgba(0, 0, 0, 0.04);
    text-transform: uppercase;
    letter-spacing: 5px;
    white-space: nowrap;
    transform: rotate(-45deg);
}

.content-layer {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    flex: 1;
}

/* Header - Compact version */
.header {
    text-align: center;
    margin-bottom: 5px;
    padding-bottom: 3px;
    border-bottom: 1.5px solid #000;
}

.school-logo {
    width: 18mm;
    height: 18mm;
    margin: 0 auto 3px;
}

.school-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
}

.school-name {
    font-size: 12px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 2px;
}

.school-address {
    font-size: 8px;
    margin-bottom: 2px;
}

.title {
    font-size: 14px;
    font-weight: bold;
    text-transform: uppercase;
    margin-bottom: 2px;
    letter-spacing: 1px;
}

.subtitle {
    font-size: 11px;
    font-weight: bold;
    margin-bottom: 2px;
}

.month-year {
    font-size: 10px;
    font-weight: bold;
    margin-top: 2px;
}

.page-number {
    float: right;
    font-size: 8px;
    margin-top: 3px;
    font-weight: bold;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #666;
}

/* Table - Optimized spacing */
.table-container {
    margin-top: 5px;
    flex: 1;
}

table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    background: transparent;
}

th, td {
    border: 1px solid #000;
    text-align: center;
    font-size: 8px;
    padding: 2px 1px;
    height: 18px;
    vertical-align: middle;
    background: transparent;
}

th {
    background: #f0f0f0;
    font-weight: 900;
    text-transform: uppercase;
    font-size: 7px;
    padding: 3px 1px;
}

td {
    background: transparent;
}

/* Column widths */
th:nth-child(1), td:nth-child(1) {
    width: 55px;
    text-align: left;
    padding-left: 6px;
    font-weight: bold;
}

th:nth-child(2), td:nth-child(2) {
    width: 30px;
    font-weight: bold;
}

/* Day columns - equal width */
th:nth-child(n+3), td:nth-child(n+3) { 
    width: auto;
}

.day-col {
    writing-mode: horizontal-tb;
    font-size: 7px;
}

/* Total rows styling */
.total-boys-row, .total-girls-row {
    background: #e8e8e8;
    font-weight: bold;
}

.total-boys-row td, .total-girls-row td {
    background: #e8e8e8;
    font-weight: bold;
}

/* Zebra striping for readability */
tbody tr:nth-child(4n+1) td,
tbody tr:nth-child(4n+2) td {
    background-color: rgba(0, 0, 0, 0.02);
}

/* Footer - Compact */
.footer {
    margin-top: 6px;
    padding-top: 5px;
    border-top: 1.5px solid #000;
    overflow: hidden;
    font-size: 9px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.total-divisions {
    font-weight: 700;
    font-size: 9px;
}

.total-students-month {
    font-weight: 900;
    font-size: 10px;
    text-align: center;
    text-transform: uppercase;
}

.generated-info {
    font-size: 8px;
    color: #666;
}

/* Print optimization */
@media print {
    html, body {
        width: 297mm;
        height: 210mm;
        margin: 0;
        padding: 0;
    }
    
    th {
        background: #f0f0f0 !important;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }
    
    td {
        background: transparent !important;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }
    
    .total-boys-row td,
    .total-girls-row td {
        background: #e8e8e8 !important;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }
    
    tbody tr:nth-child(4n+1) td,
    tbody tr:nth-child(4n+2) td {
        background-color: rgba(0, 0, 0, 0.02) !important;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }
    
    .page-container {
        border: 2px solid #000;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
        page-break-after: always;
    }
    
    .logo-watermark {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }
}
</style>
</head>

<body>

<%
const divisionsPerPage = 14; // Increased from 12 to show more rows per page
const totalPages = Math.ceil(divisions.length / divisionsPerPage);
const displayMonthYear = typeof monthYear !== 'undefined' ? monthYear : new Date().toLocaleDateString('en-IN', { month: 'long', year: 'numeric' });
const displayWorkingDays = typeof workingDays !== 'undefined' ? workingDays : 25;
const displaySchoolName = typeof schoolName !== 'undefined' ? schoolName : 'P.P.M.H.S.S. KOTTUKKARA';
const displaySchoolAddress = typeof schoolAddress !== 'undefined' ? schoolAddress : 'Kottukkara, Kondotty, Malappuram, Kerala - 673638';
const displaySchoolLogo = typeof schoolLogo !== 'undefined' ? schoolLogo : '';

// Generate day numbers
const days = [];
for (let i = 1; i <= displayWorkingDays; i++) {
    days.push(i);
}

for (let page = 0; page < totalPages; page++) {
    const startIndex = page * divisionsPerPage;
    const endIndex = Math.min(startIndex + divisionsPerPage, divisions.length);
    const pageDivisions = divisions.slice(startIndex, endIndex);
    const isFirstPage = page === 0;
    const isLastPage = page === totalPages - 1;
%>

<div class="page-container">
    
    <!-- Logo Watermark - Centered -->
    <div class="logo-watermark">
        <% if (displaySchoolLogo) { %>
            <img src="<%= displaySchoolLogo %>" alt="Watermark">
        <% } else { %>
            <div class="watermark-text"><%= displaySchoolName %></div>
        <% } %>
    </div>
    
    <div class="content-layer">
        
        <!-- Compact Header -->
        <div class="header">
            <% if (isFirstPage && displaySchoolLogo) { %>
            <div class="school-logo">
                <img src="<%= displaySchoolLogo %>" alt="School Logo">
            </div>
            <% } %>
            <div class="school-name"><%= displaySchoolName %></div>
            <div class="title">NOON MEAL PROGRAMME | <%= academicYear %></div>
            <div class="subtitle">CLASS CONSOLIDATION LIST | <%= displayMonthYear %></div>
        </div>
        
        <!-- Table Container -->
        <div class="table-container">
            <table cellspacing="0" cellpadding="0">
                <thead>
                    <tr class="header-row">
                        <th rowspan="2">Division</th>
                        <th rowspan="2">B/G</th>
                        <th colspan="<%= displayWorkingDays %>">Working Days</th>
                    </tr>
                    <tr class="header-row">
                        <% days.forEach(function(d) { %>
                            <th class="day-col"><%= d %></th>
                        <% }) %>
                    </tr>
                </thead>
                <tbody>
                    <% pageDivisions.forEach(function(div) { %>
                        <!-- Boys Row -->
                        <tr>
                            <td><%= div %></td>
                            <td>B</td>
                            <% days.forEach(function() { %>
                                <td>&nbsp;</td>
                            <% }) %>
                        </tr>
                        <!-- Girls Row -->
                        <tr>
                            <td>&nbsp;</td>
                            <td>G</td>
                            <% days.forEach(function() { %>
                                <td>&nbsp;</td>
                            <% }) %>
                        </tr>
                    <% }) %>
                    
                    <!-- Total Rows - Only on Last Page -->
                    <% if (isLastPage) { %>
                    <tr class="total-boys-row">
                        <td colspan="2" style="text-align: right; padding-right: 8px; font-weight: bold;">TOTAL BOYS</td>
                        <% days.forEach(function() { %>
                            <td>&nbsp;</td>
                        <% }) %>
                    </tr>
                    <tr class="total-girls-row">
                        <td colspan="2" style="text-align: right; padding-right: 8px; font-weight: bold;">TOTAL GIRLS</td>
                        <% days.forEach(function() { %>
                            <td>&nbsp;</td>
                        <% }) %>
                    </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
        
        <!-- Footer -->
        <div class="footer">
            <span class="total-divisions">Total Divisions: <%= divisions.length %></span>
            <span class="total-students-month">TOTAL STUDENTS FOR THIS MONTH : _____________</span>
            <span class="generated-info"><%= new Date().toLocaleDateString('en-IN') %></span>
        </div>
        
        <div class="page-number">Page <%= page + 1 %> of <%= totalPages %></div>
    </div>
</div>

<% } %>

</body>
</html>