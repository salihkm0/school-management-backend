<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Class PTA - <%= className %> <%= academicYear %></title>

<style>
@page {
    size: A4 portrait;
    margin: 5mm;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html, body {
    margin: 0;
    padding: 0;
    width: 210mm;
    font-family: "Times New Roman", serif;
    background: #fff;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
}

.page-container {
    width: 200mm;
    min-height: 277mm;
    margin: 0 auto 5mm auto;
    padding: 8mm 5mm;
    border: 2px solid #000;
    position: relative;
    page-break-after: always;
    box-sizing: border-box;
    background: #fff;
    display: flex;
    flex-direction: column;
}

.page-container:last-child {
    page-break-after: auto;
    margin-bottom: 0;
}

/* Logo Watermark */
.logo-watermark {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    pointer-events: none;
}

.logo-watermark img {
    width: 120mm;
    height: 120mm;
    object-fit: contain;
    opacity: 0.06;
}

.content-layer {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    flex: 1;
}

/* Main content */
.main-content {
    flex: 1;
}

/* Header Section */
.header-section {
    text-align: center;
    margin-bottom: 10px;
    padding-bottom: 5px;
    border-bottom: 2px solid #000;
}

.school-logo {
    width: 20mm;
    height: 20mm;
    margin: 0 auto 5px;
}

.school-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
}

.school-name {
    font-size: 14px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 2px;
}

.arabic-text {
    font-size: 10px;
    font-weight: bold;
    margin-bottom: 3px;
    color: #333;
}

.main-title {
    font-size: 16px;
    font-weight: 900;
    text-transform: uppercase;
    text-decoration: underline;
    margin: 5px 0;
}

.class-info {
    font-size: 12px;
    font-weight: 700;
    margin-top: 3px;
}

.page-number {
    text-align: center;
    font-size: 9px;
    margin: 5px 0;
    font-weight: bold;
}

/* Main Table */
.main-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 10px;
    margin-top: 5px;
}

.main-table th,
.main-table td {
    border: 1.5px solid #000;
    padding: 6px 3px;
    text-align: center;
    vertical-align: middle;
}

.main-table th {
    background: #f0f0f0;
    font-weight: 900;
    text-transform: uppercase;
    font-size: 9px;
    padding: 6px 3px;
}

.main-table td {
    background: transparent;
}

/* Column widths */
.main-table .sl-col { width: 7%; }
.main-table .adm-col { width: 10%; }
.main-table .name-col { width: 28%; text-align: left; padding-left: 5px; }
.main-table .parent-col { width: 28%; text-align: left; padding-left: 5px; }
.main-table .sign-col { width: 27%; }

/* Bottom Section */
.bottom-section {
    margin-top: auto;
    padding-top: 15px;
}

/* Signature Section */
.signature-section {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-top: 15px;
}

.signature-item {
    text-align: center;
    width: 150px;
}

.signature-line {
    margin-top: 25px;
    border-top: 1.5px solid #000;
    width: 100%;
}

.signature-label {
    font-size: 10px;
    font-weight: bold;
    margin-top: 5px;
}

/* Footer */
.footer {
    margin-top: 10px;
    padding-top: 5px;
    border-top: 1px solid #000;
    overflow: hidden;
    font-size: 9px;
}

.total-students {
    float: left;
    font-weight: 700;
}

.generated-info {
    float: right;
}

/* Print optimization */
@media print {
    html, body {
        width: 210mm;
        margin: 0;
        padding: 0;
    }
    
    th {
        background: #f0f0f0 !important;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }
    
    td {
        background: transparent !important;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }
    
    .page-container {
        border: 2px solid #000;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
        page-break-after: always;
    }
    
    .logo-watermark img {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }
}
</style>
</head>

<body>

<%
const studentsPerPage = 30;
const totalPages = Math.ceil(students.length / studentsPerPage);
const displayAcademicYear = typeof academicYear !== 'undefined' ? academicYear : '2025-2026';
const displayClassName = typeof className !== 'undefined' ? className : '10 A';
const schoolLogo = typeof schoolLogoUrl !== 'undefined' ? schoolLogoUrl : 'https://res.cloudinary.com/dmjqgjcut/image/upload/v1769946977/school-logo_uugskb.jpg';

for (let page = 0; page < totalPages; page++) {
    const startIndex = page * studentsPerPage;
    const endIndex = Math.min(startIndex + studentsPerPage, students.length);
    const pageStudents = students.slice(startIndex, endIndex);
    const isLastPage = page === totalPages - 1;
%>

<div class="page-container">
    
    <!-- Logo Watermark -->
    <div class="logo-watermark">
        <img src="<%= schoolLogo %>" alt="Watermark">
    </div>
    
    <div class="content-layer">
        
        <div class="main-content">
            
            <!-- Header -->
            <div class="header-section">
                <div class="school-logo">
                    <img src="<%= schoolLogo %>" alt="School Logo">
                </div>
                <div class="school-name">P.P.M.H.S.S. KOTTUKKARA</div>
                <!-- <div class="arabic-text">العلم نور &nbsp;&nbsp; العلم نور</div> -->
                <div class="main-title">Class PTA</div>
                <div class="class-info">(Standard and Division - <%= displayClassName %> <%= displayAcademicYear %>)</div>
            </div>
            
            <!-- Main Table -->
            <table class="main-table">
                <thead>
                    <tr>
                        <th class="sl-col">Sl No</th>
                        <th class="adm-col">Adm No</th>
                        <th class="name-col">Name of Student</th>
                        <th class="parent-col">Name of Parent/Guardian</th>
                        <th class="sign-col">Signature of Parent</th>
                    </tr>
                </thead>
                <tbody>
                    <% pageStudents.forEach(function(student, index) { 
                        const slNo = startIndex + index + 1;
                    %>
                    <tr>
                        <td><%= slNo %></td>
                        <td><%= student.admissionNo %></td>
                        <td style="text-align: left; padding-left: 5px;"><%= student.name %></td>
                        <td style="text-align: left; padding-left: 5px;"><%= student.parentName || '' %></td>
                        <td></td>
                    </tr>
                    <% }); %>
                    
                    <% 
                    const remainingRows = studentsPerPage - pageStudents.length;
                    for (let i = 0; i < remainingRows; i++) {
                    %>
                    <!-- <tr>
                        <td>-</td>
                        <td>-</td>
                        <td style="text-align: left;">-</td>
                        <td style="text-align: left;"></td>
                        <td></td>
                    </tr> -->
                    <% } %>
                </tbody>
            </table>
            
        </div>
        
        <!-- Bottom Section -->
        <div class="bottom-section">
            
            <!-- Signatures - Only on Last Page -->
            <% if (isLastPage) { %>
            <div class="signature-section">
                <div class="signature-item">
                    <div class="signature-label">Class Teacher</div>
                    <div class="signature-line"></div>
                </div>
                <div class="signature-item">
                    <div class="signature-label">PTA President</div>
                    <div class="signature-line"></div>
                </div>
                <div class="signature-item">
                    <div class="signature-label">Principal</div>
                    <div class="signature-line"></div>
                </div>
            </div>
            <% } %>
            
            <!-- Footer -->
            <div class="footer">
                <span class="total-students">Total Students: <%= students.length %></span>
                <span class="generated-info">Generated on: <%= new Date().toLocaleDateString('en-IN') %></span>
            </div>
            
        </div>
        
        <div class="page-number">Page <%= page + 1 %> of <%= totalPages %></div>
        
    </div>
</div>

<% } %>

</body>
</html>